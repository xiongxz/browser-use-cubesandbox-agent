{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "browser_agent_run",
  "type": "object",
  "additionalProperties": false,
  "required": ["query"],
  "properties": {
    "query": {
      "type": "string",
      "description": "Natural language instruction for the browser agent."
    },
    "start_url": {
      "type": "string",
      "description": "Optional URL to open before the agent starts reasoning."
    },
    "allowed_domains": {
      "type": "array",
      "description": "Optional Browser Use allowed_domains restrictions.",
      "items": {
        "type": "string"
      }
    },
    "headless": {
      "type": "boolean",
      "description": "Whether to run the browser in headless mode."
    },
    "max_steps": {
      "type": "integer",
      "minimum": 1,
      "maximum": 120,
      "default": 35
    },
    "timeout_sec": {
      "type": "integer",
      "minimum": 30,
      "maximum": 3600,
      "default": 600
    },
    "use_vision": {
      "type": "string",
      "enum": ["auto", "always", "never"],
      "default": "auto"
    },
    "llm": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "base_url": {
          "type": "string"
        },
        "api_key": {
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "temperature": {
          "type": "number",
          "minimum": 0,
          "maximum": 2
        }
      }
    },
    "auth": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "profile_id": {
          "type": "string",
          "description": "Server-side stored auth profile id, for example a saved Feishu login state."
        },
        "storage_state": {
          "type": "object",
          "description": "Playwright storage state JSON object for authenticated sessions."
        },
        "storage_state_path": {
          "type": "string",
          "description": "Path to an existing storage state file inside the container."
        },
        "sensitive_data": {
          "type": "object",
          "description": "Optional Browser Use sensitive_data payload."
        }
      }
    }
  }
}
