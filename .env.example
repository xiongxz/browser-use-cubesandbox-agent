# All values below are OPTIONAL at startup.
# When the sandbox cannot accept env vars at creation time, you can leave the
# LLM_* fields empty here and POST them to /v1/init after the container boots.
# /healthz reports which keys are still missing.

PORT=49999
HOST=0.0.0.0
LOG_LEVEL=info

# OpenAI-compatible LLM config used by browser-use ChatOpenAI.
# Also injectable at runtime via /v1/init { llm_base_url, llm_api_key, llm_model, llm_temperature }.
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4.1-mini
LLM_TEMPERATURE=0

# Browser defaults. Also injectable via /v1/init.
BROWSER_HEADLESS=true
BROWSER_WINDOW_WIDTH=1440
BROWSER_WINDOW_HEIGHT=900
BROWSER_ARTIFACTS_DIR=/tmp/browser-agent-artifacts
BROWSER_USE_CONFIG_DIR=/tmp/browseruse-config
PLAYWRIGHT_BROWSERS_PATH=/tmp/playwright-browsers

# Persistent auth storage for profiles such as Feishu login state.
# AUTH_STATE_DIR is NOT runtime-injectable (path changes mid-flight break references).
AUTH_STATE_DIR=/tmp/browser-agent-auth
FEISHU_DEFAULT_PROFILE_ID=feishu-default

# How long a Feishu draft session lives between phase 1 and phase 2 (seconds).
# Not currently runtime-injectable; set at boot time only.
DRAFT_SESSION_TTL_SEC=1800

# --- MCP server (optional) ---
# When ENABLE_MCP=true, the FastAPI app mounts an MCP streamable-HTTP server
# at /mcp on the same port (default 49999). Tools route back to /v1/agent/run
# in-process, so no extra port is required. See mcp_server/server.py.
ENABLE_MCP=false
# Optional override for the FastAPI base URL the MCP tools proxy to.
# Defaults to http://127.0.0.1:${PORT}; you only need to change it when running
# the MCP server in a separate process or container.
# MCP_PROXY_BASE=http://127.0.0.1:49999
# Long timeout because Feishu publish flows can take several minutes.
# MCP_PROXY_TIMEOUT_SEC=1200
